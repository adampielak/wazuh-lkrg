 <group name="lkrg,kernel,security,">
    <!-- LKRG - loading logs from kernel -->
<!--
    <rule id="130070" level="0">
      <program_name>kernel</program_name>
      <match>LKRG:</match>
      <description>LKRG: Kernel message detected on $(hostname)</description>
    </rule>
-->
    <!-- FATAL errors - highest severity -->
    <rule id="130071" level="12">
      <program_name>kernel</program_name>
        <match>LKRG: FATAL:</match>
        <description>LKRG: FATAL - Critical error, kernel protection is NOT working on $(hostname)</description>
        <group>lkrg,fatal,security</group>
    </rule>

    <!-- FAULT - very high severity -->
    <rule id="130072" level="10">
      <program_name>kernel</program_name>
        <match>LKRG: FAULT:</match>
        <description>LKRG: FAULT - Major functional error detected in LKRG on $(hostname)</description>
        <group>lkrg,fault,security</group>
    </rule>

    <!-- DYING - critical, usually module unloads or init failures -->
    <rule id="130073" level="10">
      <program_name>kernel</program_name>
        <match>LKRG: DYING:</match>
        <description>LKRG: DYING - LKRG is shutting down, unloading, or failed to initialize on $(hostname)</description>
        <group>lkrg,dying,security</group>
    </rule>

    <!-- ALERT - detection/blocking events, medium-high severity -->
    <rule id="130074" level="9">
      <program_name>kernel</program_name>
        <match>LKRG: ALERT:</match>
        <description>LKRG: ALERT - Security alert or protection event in kernel detected on $(hostname)</description>
        <group>lkrg,alert,security</group>
    </rule>

    <!-- ISSUE - system lacks protections, hook failures, etc -->
    <rule id="130075" level="7">
      <program_name>kernel</program_name>
        <match>LKRG: ISSUE:</match>
        <description>LKRG: ISSUE - Warning: kernel feature missing or LKRG hook failed on $(hostname)</description>
        <group>lkrg,issue,security</group>
    </rule>

    <!-- STATE - configuration/enable/disable -->
    <rule id="130076" level="5">
      <program_name>kernel</program_name>
        <match>LKRG: STATE:</match>
        <description>LKRG: STATE - Configuration or kernel state change detected on $(hostname)</description>
        <group>lkrg,state,info</group>
    </rule>

    <!-- WATCH - observations, not errors -->
    <rule id="130077" level="4">
      <program_name>kernel</program_name>
        <match>LKRG: WATCH:</match>
        <description>LKRG: WATCH - Informational event or observation from LKRG on $(hostname)</description>
        <group>lkrg,watch,info</group>
    </rule>

    <!-- ALIVE - module init, system status -->
    <rule id="130078" level="3">
      <program_name>kernel</program_name>
        <match>LKRG: ALIVE:</match>
        <description>LKRG: ALIVE - LKRG loaded, running, or system is clean on $(hostname)</description>
        <group>lkrg,alive,info</group>
    </rule>

    <!-- DEBUG logs (optionally drop or keep on lowest level) -->
    <rule id="130079" level="2">
      <program_name>kernel</program_name>
        <match>LKRG: DEBUG:</match>
        <description>LKRG: DEBUG - Debugging message from LKRG on $(hostname)</description>
        <group>lkrg,debug,info</group>
    </rule>
    <!-- FLOOD logs (optionally drop or keep on lowest level) -->
    <rule id="130080" level="2">
      <program_name>kernel</program_name>
        <match>LKRG: FLOOD:</match>
        <description>LKRG: FLOOD - Repetitive debug or flood message from LKRG on $(hostname)</description>
        <group>lkrg,debug,info</group>
    </rule>
  </group>
